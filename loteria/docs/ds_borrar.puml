@startuml DS_Borrar
!theme plain

title Diagrama de Secuencia\nDS03 - Borrar Número de Lotería

participant "Administrador" as Actor
participant "MenuPrincipal" as UI <<boundary>>
participant "ServicioLoteria" as Servicio <<control>>
participant "RepositorioLoteria" as Repo <<entity>>
participant "loteria.json" as DB <<database>>

Actor -> UI : ejecutar()
activate UI

UI -> UI : mostrar_menu()
UI --> Actor : Muestra opciones
Actor -> UI : opcion = "3"
UI -> UI : borrar_numero()

UI -> Servicio : listar_numeros()
activate Servicio
Servicio -> Repo : obtener_todos()
activate Repo
Repo -> DB : load JSON
Repo --> Servicio : lista_numeros
deactivate Repo
Servicio --> UI : lista_numeros
deactivate Servicio

UI --> Actor : Muestra lista de números
Actor -> UI : selecciona índice = 1

UI -> UI : mostrar_numero(seleccionado)
UI --> Actor : Muestra datos del número
UI --> Actor : "¿Está seguro? (s/n)"
Actor -> UI : "s"

UI -> Servicio : borrar_numero("uuid-xxx")
activate Servicio

Servicio -> Repo : obtener_por_id("uuid-xxx")
activate Repo
Repo -> DB : load JSON
Repo --> Servicio : numero_existente
deactivate Repo

Servicio -> Repo : eliminar("uuid-xxx")
activate Repo
Repo -> DB : load JSON
Repo -> Repo : filtrar registros
Repo -> DB : save JSON
Repo --> Servicio : true
deactivate Repo

Servicio --> UI : true
deactivate Servicio

UI --> Actor : "✅ Número eliminado exitosamente"

deactivate UI

@enduml
